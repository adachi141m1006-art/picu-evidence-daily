# ============================================
# PICU Evidence Daily — 環境変数設定
# ============================================
# このファイルを .env にコピーして値を設定してください
# cp config.env.example .env

# --- 必須 ---
# Anthropic Claude API Key
# 取得: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# --- 推奨 ---
# NCBI (PubMed) API Key（rate limit緩和: 3→10 req/sec）
# 取得: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Instagram投稿用 ---
# Instagram Graph API Access Token (長期トークン)
# セットアップ手順は運用ガイド参照
INSTAGRAM_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxx
INSTAGRAM_ACCOUNT_ID=17841400000000000

# --- 画像ホスティング用 ---
# Imgur API Client ID
# 取得: https://api.imgur.com/oauth2/addclient
IMGUR_CLIENT_ID=xxxxxxxxxxxxxxx

# --- 通知用（任意） ---
# LINE Notify Token
# 取得: https://notify-bot.line.me/
LINE_NOTIFY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
